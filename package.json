{
  "name": "duel-spirits",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server:dev": "wrangler dev",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "sim:test": "node scripts/run-simulator.mjs self-test",
    "sim:meta": "node scripts/run-simulator.mjs cli",
    "check": "npm run test:run && npm run build",
    "server:deploy": "wrangler deploy",
    "server:tail": "wrangler tail",
    "server:whoami": "wrangler whoami",
    "art:check": "node scripts/check-card-art.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260625.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wrangler": "4.105.0"
  },
  "dependencies": {
    "partysocket": "1.3.0",
    "partyserver": "0.5.8"
  }
}
