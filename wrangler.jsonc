{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "card-duel-server",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-02",
  "durable_objects": {
    "bindings": [
      {
        "name": "Main",
        "class_name": "Main"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Main"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
